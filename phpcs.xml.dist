<?xml version="1.0"?>
<ruleset name="Lamixtape Theme">
    <description>
        PHPCS configuration for the Lamixtape WordPress theme.

        Based on WPCS WordPress-Core (basic non-opinionated rules) +
        WordPress-Docs (PHPDoc / inline comments standards). WordPress-Extra
        is intentionally NOT included — it carries strong opinions on
        structure (Yoda conditions, function naming, etc.) that don't all
        align with the theme's existing style established in Phases 0-8.

        Documentation : https://github.com/WordPress/WordPress-Coding-Standards
    </description>

    <!-- Files / paths to scan -->
    <file>.</file>

    <!-- Exclusions : non-PHP code, build artifacts, vendored libs -->
    <exclude-pattern>/node_modules/*</exclude-pattern>
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/_docs/audit/*</exclude-pattern>
    <exclude-pattern>/assets/build/*</exclude-pattern>
    <exclude-pattern>/assets/vendor/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>wp-config.php</exclude-pattern>

    <!-- Only check PHP files -->
    <arg name="extensions" value="php"/>

    <!-- Show progress + display sniff codes -->
    <arg value="ps"/>
    <arg name="colors"/>

    <!-- Parallel execution : 4 cores (most modern devs) -->
    <arg name="parallel" value="4"/>

    <!-- Memory limit : phpcs default 128M can be tight on large repos -->
    <ini name="memory_limit" value="256M"/>

    <!--
        Rulesets included — strategy: STRICT on security/correctness,
        RELAXED on cosmetic formatting. Solo-developer workflow,
        thème personnel non-publié. The cosmetic excludes below are
        documented per group with rationale. WPCS security/correctness
        sniffs (Security.*, DB.PreparedSQL*, WP.AlternativeFunctions,
        WP.GlobalVariablesOverride, PHP.NoSilencedErrors,
        PHP.StrictInArray, Security.NonceVerification) remain active
        and currently report 0 violations on the theme codebase
        (validated post-Phase-A2 baseline run).

        - WordPress-Core : basic, non-opinionated WP coding standards
          (file naming, indentation, basic security, escape patterns)
        - WordPress-Docs : PHPDoc + inline comment standards
    -->
    <rule ref="WordPress-Core">
        <!--
            PrefixAllGlobals family — inopérant pour notre prefix
            "lmt" (3 chars) à cause de la constante PHP
            `MIN_PREFIX_LENGTH = 4` dans
            vendor/wp-coding-standards/wpcs/WordPress/Sniffs/
            NamingConventions/PrefixAllGlobalsSniff.php:69 + le
            `continue;` qui skip total l'enregistrement du prefix
            après l'erreur ShortPrefixPassed (ligne 1252). Tous les
            variants downstream (NonPrefixedFunctionFound /
            NonPrefixedVariableFound / NonPrefixedHooknameFound /
            NonPrefixedConstantFound / etc.) consultent un cache
            $validated_prefixes vide pour `lmt` → 100% faux positifs
            sur du code conforme. À réactiver si le préfixe thème
            passe à 4+ chars (ex. rename `lmt_*` → `lamixtape_*`).
        -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals"/>

        <!--
            Cosmetic sniffs disabled below — see CLAUDE.md
            apprentissage WPCS-RELAX for the rationale by group.
            Counts ci-dessous = nombre d'occurrences au baseline
            run pre-relax (Phase ad-hoc CI fix).
        -->

        <!-- 1071 occurrences. Conflit fondamental : WPCS impose
             tabs, le thème (et .editorconfig Phase A2) utilise
             4-space indent partout. Le thème a la priorité. -->
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>

        <!-- ~155 (4 variants : SpaceBeforeCloseBracket /
             SpaceAfterOpenBracket / CloseBracketLine /
             ContentAfterOpenBracket / MultipleArguments). PEAR
             impose un format strict des appels de fonction
             multi-paramètres ; le thème utilise un style plus
             concis. -->
        <exclude name="PEAR.Functions.FunctionCallSignature"/>

        <!-- 25 occurrences. Alignement strict des `=` dans des
             blocs successifs. Cosmétique, pas de bénéfice
             lisibilité significatif. -->
        <exclude name="Generic.Formatting.MultipleStatementAlignment"/>

        <!-- 16. Alignement strict des items d'array sur 4 spaces.
             Couplé à DisallowSpaceIndent désactivé, cohérent. -->
        <exclude name="WordPress.Arrays.ArrayIndentation"/>

        <!-- 11. Whitespace de précision (.5 indent). Cosmétique. -->
        <exclude name="Universal.WhiteSpace.PrecisionAlignment"/>

        <!-- 9. Quotes simples préférées si pas d'interpolation.
             Le thème utilise des doubles quotes selon le contexte
             (concaténation HTML, etc.). Style assumé. -->
        <exclude name="Squiz.Strings.DoubleQuoteUsage"/>

        <!-- 9. Spacing strict autour de l'opérateur `.`
             (concaténation). Cosmétique. -->
        <exclude name="Squiz.Strings.ConcatenationSpacing"/>

        <!-- 9. Format des commentaires inline (point final
             obligatoire, etc.). Cosmétique. -->
        <exclude name="Squiz.Commenting.InlineComment"/>

        <!-- 9. Spacing strict après virgule dans les arguments
             de fonction. Cosmétique. -->
        <exclude name="Generic.Functions.FunctionCallArgumentSpacing"/>

        <!-- 8. PHPDoc strict : @param doit avoir un commentaire
             texte. Le thème PHPDoc est complet sur les types mais
             omet le texte trivial. -->
        <exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>

        <!-- 13 (2 variants). Format strict des structures de
             contrôle (newline après brace, space après keyword).
             Cosmétique. -->
        <exclude name="Squiz.ControlStructures.ControlSignature"/>

        <!-- 21. Spacing strict dans les structures de contrôle
             (parenthèses, alt syntax, etc.). Cosmétique. -->
        <exclude name="WordPress.WhiteSpace.ControlStructureSpacing"/>

        <!-- 6. File-level docblock strict (`/**` requis,
             @package etc.). Le thème a des header docblocks mais
             pas dans le format Squiz. -->
        <exclude name="Squiz.Commenting.FileComment"/>

        <!-- 7. Indent strict avec exact match. Couplé à
             DisallowSpaceIndent désactivé. -->
        <exclude name="Generic.WhiteSpace.ScopeIndent"/>

        <!--
            Pass 3 résiduels — sniffs additionnels désactivés post
            premier round de relax. 32-34 occurrences au pass 3
            baseline. Same rationale: cosmétique, incompatible
            avec le style du thème ou avec WP template patterns.
        -->

        <!-- 22 occurrences (6 variants : SpacingBeforeClose /
             ContentBeforeEnd / ContentAfterOpen / NoSemicolon /
             ContentBeforeOpen / ContentAfterEnd). Squiz impose
             que `<?php` et `?>` soient sur des lignes dédiées
             (3 lignes minimum par bloc inline). Incompatible
             avec le style WP template `<?php the_title(); ?>`
             où l'inline est PARTOUT (header.php, footer.php,
             single.php, etc.). -->
        <exclude name="Squiz.PHP.EmbeddedPhp"/>

        <!-- 2. Yoda conditions (`if ( true === $foo )`) sont un
             anti-pattern moderne en 2026. Le style naturel
             `if ( $foo === true )` est plus lisible. -->
        <exclude name="WordPress.PHP.YodaConditions"/>

        <!-- 2. Short ternary `$foo ?: $bar` est PHP 5.3+ et
             largement accepté en 2026 (équivalent compact à
             `$foo ? $foo : $bar`). -->
        <exclude name="Universal.Operators.DisallowShortTernary"/>

        <!-- 3. Spacing strict autour des opérateurs (`!`, `==`,
             etc.). Cosmétique. -->
        <exclude name="WordPress.WhiteSpace.OperatorSpacing"/>

        <!-- 2. Alignement strict des `=>` dans les arrays
             multi-lignes. Cosmétique. -->
        <exclude name="WordPress.Arrays.MultipleStatementAlignment"/>

        <!-- 2 (single.php include "player.php" + footer.php
             include "analytics.php"). Style choice : `include`
             ne crash pas si fichier manque, `require` si. Pour
             des partials de template, `include` est défensif
             acceptable. -->
        <exclude name="PEAR.Files.IncludingFile.UseRequire"/>

        <!-- 1. Trailing comma multi-line array. PHP 7.3+
             supporte mais n'impose pas. Cosmétique. -->
        <exclude name="NormalizedArrays.Arrays.CommaAfterLast"/>

        <!-- 2 (SpacingBeforeTags + LongNotCapital). Format
             strict des PHPDoc (espace avant tags, capitalisation
             des descriptions longues). Cosmétique. -->
        <exclude name="Generic.Commenting.DocComment"/>
    </rule>
    <rule ref="WordPress-Docs"/>

    <!--
        Theme-specific overrides — exceptions justifiées par le contexte
        Lamixtape (Phases 0-8 du refacto). Chaque exclusion porte un commentaire
        explicite expliquant POURQUOI la règle ne s'applique pas ici.
    -->

    <!--
        Le thème est custom (non-publié, single-site). Le text-domain
        'lamixtape' est utilisé dans tout le code (Phase 2 QC-004 fix).
    -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="lamixtape"/>
            </property>
        </properties>
    </rule>

    <!--
        Le préfixe `lmt_` est utilisé pour toutes les fonctions et
        hooks du thème (Phase 2 décision D6, CLAUDE.md section 8).
    -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="lmt"/>
                <element value="Lamixtape"/>
            </property>
        </properties>
    </rule>

    <!--
        File naming : WPCS attend file-name.php (avec tirets), le thème
        utilise déjà ce format. Pas d'override nécessaire.
    -->

    <!--
        Le thème supporte PHP >=8.2 (prod confirmée). Les rules de
        compat PHP 5.x sont sans intérêt.
    -->
    <config name="testVersion" value="8.2-"/>

    <!--
        Le thème supporte WP >=6.0 (à confirmer post-déploiement).
        Cette valeur permet aux sniffs WPCS qui le supportent de
        signaler les usages d'API plus récentes que la cible.
    -->
    <config name="minimum_supported_wp_version" value="6.0"/>
</ruleset>
