# .env.example — Template pour le déploiement SFTP OVH
#
# Copier ce fichier vers .env (gitignored) et remplir les vraies valeurs.
# NE JAMAIS committer .env (contient le mot de passe SFTP).
#
# Usage :
#     cp .env.example .env
#     # éditer .env, remplir SFTP_PASSWORD
#     bash bin/deploy-sftp.sh --connect-test

# OVH SFTP credentials (cf. manager OVH > Web Cloud > Hosting > FTP-SSH)
# IMPORTANT : vérifier le numéro exact du cluster dans le manager OVH
# (peut être 005, 105, 027, etc. selon le compte). Le default cluster105
# ci-dessous est INDICATIF — à corriger dans le .env local si différent.
SFTP_HOST=ftp.cluster105.hosting.ovh.net
SFTP_USER=lamixtapuw
SFTP_PORT=22
SFTP_PASSWORD=your_password_here

# Path destination côté serveur OVH.
# IMPORTANT : LOWERCASE strict (Linux case-sensitive). Le repo git
# local s'appelle "Lamixtape" (L majuscule, macOS case-insensitive)
# mais sur le serveur Linux le dossier doit être "lamixtape" pour
# matcher l'install WordPress active. Synchroniser vers "Lamixtape"
# créerait un nouveau dossier à côté de l'existant.
SFTP_REMOTE_PATH=www/wp-content/themes/lamixtape

# Path source local (le dossier du thème courant).
# `.` = le dossier racine du repo, résolu par bin/deploy-sftp.sh
# via $THEME_DIR (computed depuis le SCRIPT_DIR).
LOCAL_THEME_PATH=.
