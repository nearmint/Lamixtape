# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo

# Dependencies (anticipation Phase 4 Tailwind)
# NOTE: anchored at root so /vendor/ (Composer) is ignored but
# assets/vendor/ (self-hosted libs) is tracked.
/node_modules/
/vendor/

# Logs
*.log

# Build output at theme root only — assets/build/ stays tracked
# (it hosts the local Tailwind CLI binary path, see below).
/dist/
/build/

# Tailwind CLI standalone binary (Phase 4 Axe A.1)
# Each developer downloads their own platform binary into
# assets/build/ and runs it locally; the generated CSS
# (assets/css/tailwind.css) IS tracked.
assets/build/tailwindcss
assets/build/tailwindcss.exe

# WordPress
wp-config.php
